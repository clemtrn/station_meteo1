    {
        "id": "c3a9f48d5b2e1a3c",
        "type": "function",
        "z": "b182cb4497bc3964",
        "name": "Dispatch & Historique",
        "func": "let donneesRobot = msg.payload;\n\nlet nouvelleMesure = {\n    temperature: donneesRobot.temperature || 0,\n    humidite: donneesRobot.humidite || 0,\n    pression: donneesRobot.pression || 0,\n    luminosite: donneesRobot.luminosite || 0,\n    date: new Date().toLocaleString(\"fr-FR\")\n};\n\nglobal.set(\"mesure_actuelle\", nouvelleMesure);\n\nlet historique = global.get(\"historique\") || [];\nhistorique.unshift(nouvelleMesure);\nif (historique.length > 100) { historique.pop(); }\nglobal.set(\"historique\", historique);\n\nlet msgReponse = { payload: { status: \"OK\", message: \"Données reçues !\" } };\nlet msgTemp = { payload: donneesRobot.temperature };\nlet msgHum = { payload: donneesRobot.humidite };\nlet msgPres = { payload: donneesRobot.pression };\nlet msgLum = { payload: donneesRobot.luminosite };\n\nreturn [msgReponse, msgTemp, msgHum, msgPres, msgLum];",
        "outputs": 5,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
