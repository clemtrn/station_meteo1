    {
        "id": "fn_actuel",
        "type": "function",
        "z": "b182cb4497bc3964",
        "name": "Renvoi actuel",
        "func": "// 1. On récupère la donnée dans le global\nlet mesure = global.get(\"mesure_actuelle\");\n\n// 2. On injecte la donnée UNIQUEMENT dans le payload sans toucher au reste du msg\nif (mesure) {\n    msg.payload = mesure;\n} else {\n    msg.payload = { error: \"Aucune donnee en memoire. Cliquez sur le simulateur !\" };\n}\n\n// 3. On renvoie le msg intact\nreturn msg;",
