    {
        "id": "65f6c4d751fae29c",
        "type": "function",
        "z": "44a3fd755ef6adb3",
        "name": "Historique et envoi",
        "func": "let donneesRobot = msg.payload; //récupère les données envoyées\n\nlet nouvelleMesure = {\n    //si les valeurs envoyées ne sont pas trouvables le code écrit un 0 au lieu d'avoir une valeur vide\n    temperature: donneesRobot.temperature || 0,\n    humidite: donneesRobot.humidite || 0,\n    pression: donneesRobot.pression || 0,\n    luminosite: donneesRobot.luminosite || 0,\n    vitesse_m_s: donneesRobot.vitesse_m_s || 0,\n    dirVent: donneesRobot.dirVent || 0,\n    angleVent: donneesRobot.angleVent || 0,\n    pluie_mm: donneesRobot.pluie_mm || 0,\n    //donne la date et l'heure sur le fuseau horaire de paris\n    date: new Date().toLocaleString(\"fr-FR\", { timeZone: \"Europe/Paris\" }) };\n\nglobal.set(\"mesure_actuelle\", nouvelleMesure);//range l'objet nouvelleMesure dans un tiroir de la mémoire globale appelé \"mesure_actuelle\"\n\nlet historique = global.get(\"historique\") || [];//créé une liste vide pour l'historique\nhistorique.unshift(nouvelleMesure);//insère la toute nouvelle mesure tout en haut de la liste\n//si l'historique dépasse 100 lignes, le mot pop() jette automatiquement la mesure la plus vieille pour éviter les problèmes de mémoire\nif (historique.length > 100) { historique.pop(); }\nglobal.set(\"historique\", historique);//range les nouveautés dans la mémoire \n\n//distribue les messages aux sorties correspondantes\nlet msgReponse = { payload: { status: \"OK\", message: \"Données reçues !\" } };\nlet msgTemp = { payload: donneesRobot.temperature };\nlet msgHum = { payload: donneesRobot.humidite };\nlet msgPres = { payload: donneesRobot.pression };\nlet msgLum = { payload: donneesRobot.luminosite };\nlet msgVit = { payload: donneesRobot.vitesse_m_s };\nlet msgDir = { payload: donneesRobot.dirVent };\nlet msgAng = { payload: donneesRobot.angleVent };\nlet msgPlu = { payload: donneesRobot.pluie_mm };\n\nreturn [msgReponse, msgTemp, msgHum, msgPres, msgLum, msgVit, msgDir, msgAng, msgPlu];",
        "outputs": 9,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 504,
        "y": 262,
        "wires": [
